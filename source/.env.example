# Operator Engagement Researcher — Pipeline Environment Variables
# Copy to .env and add your keys. Never commit .env to git.

# Required for market gap queries (Perplexity Sonar)
PERPLEXITY_API_KEY=your_key_here

# Required for digest generation (Anthropic claude-haiku)
ANTHROPIC_API_KEY=your_key_here

# Required for competitor URL monitoring (Firecrawl)
FIRECRAWL_API_KEY=your_key_here

# Optional — only needed if using email delivery (Resend)
RESEND_API_KEY=your_key_here
RESEND_FROM_EMAIL=your_verified_sender@yourdomain.com
RESEND_TO_EMAIL=your@email.com

# Google Trends: free, no key required
# Reddit: free, no auth required
